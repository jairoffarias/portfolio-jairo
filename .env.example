# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jairofarias.com

# ── Sanity CMS ───────────────────────────────────────────────────
# Create a free project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
# Only needed for the seed script (write access):
SANITY_API_WRITE_TOKEN=

# ── Supabase (contact form storage) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (contact form email notifications) ───────────────────
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=hello@jairofarias.com
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# ── Cloudflare Turnstile (spam protection) ──────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
